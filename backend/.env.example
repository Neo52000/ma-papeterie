# =========================================================
# CRM ma-papeterie.fr — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =========================================================

# Serveur
PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://srv1475682.hstgr.cloud

# Base de données Supabase
# Récupérer l'URL dans Supabase → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
DATABASE_SSL=true

# JWT
JWT_SECRET=changez-moi-par-une-chaine-aleatoire-longue
JWT_REFRESH_SECRET=changez-moi-aussi-different-du-premier

# API Key pour n8n et integrations externes
API_KEY=votre-cle-api-secrete

# IA — choisir 'anthropic' ou 'openai'
AI_PROVIDER=anthropic

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# OpenAI (si AI_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# SMTP Hostinger (ou autre)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@ma-papeterie.fr
SMTP_PASS=votre-mot-de-passe-smtp
SMTP_FROM_NAME=ma-papeterie.fr

# IMAP (lecture emails entrants, optionnel)
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=contact@ma-papeterie.fr
IMAP_PASS=votre-mot-de-passe-imap
