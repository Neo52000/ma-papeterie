        {
          "id": "call-sirene-api",
          "name": "API Sirene — Recherche entreprises",
          "type": "n8n-nodes-base.httpRequest",
          "position": [540, 300],
          "parameters": {
            "method": "GET",
            "url": "https://api.insee.fr/entreprises/sirene/V3.11/siret",
            "authentication": "headerAuth",
            "headerAuthKey": "Authorization",
            "headerAuthValue": "Bearer ={{$env.INSEE_API_TOKEN}}",
            "queryParameters": {
              "parameters": [
                {"name": "q", "value": "codePostalEtablissement:52*"},
                {"name": "nombre", "value": "1000"},
                {"name": "champs", "value": "siret,denominationUniteLegale,activitePrincipaleUniteLegale,codePostalEtablissement,libelleCommuneEtablissement,coordonneeLambertAbscisseEtablissement,coordonneeLambertOrdonneeEtablissement,trancheEffectifsUniteLegale,adresseEtablissement"}
              ]
            }
          }
        },
        {
          "id": "filter-distance",
          "name": "Filtrer rayon 20km",
          "type": "n8n-nodes-base.code",
          "position": [760, 300],
          "parameters": {
            "jsCode": "const CHAUMONT_LAT = 48.111338;\nconst CHAUMONT_LNG = 5.138481;\nconst RAYON_KM = 20;\n\nfunction haversine(lat1, lon1, lat2, lon2) {\n  const R = 6371;\n  const dLat = (lat2 - lat1) * Math.PI / 180;\n  const dLon = (lon2 - lon1) * Math.PI / 180;\n  const a =\n    Math.sin(dLat/2) * Math.sin(dLat/2) +\n    Math.cos(lat1 * Math.PI / 180) *\n    Math.cos(lat2 * Math.PI / 180) *\n    Math.sin(dLon/2) * Math.sin(dLon/2);\n  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));\n}\n\nconst items = $input.all();\nconst result = [];\n\nfor (const item of items) {\n  const etablissements = item.json?.etablissements || [];\n  for (const etab of etablissements) {\n    // Convertir Lambert93 → WGS84 simplifié (ou utiliser géocodage si disponible)\n    const cp = etab.adresseEtablissement?.codePostalEtablissement || '';\n    if (!cp.startsWith('52')) continue;\n\n    // Geocoding approximatif basé code postal — à affiner avec API géocodage\n    result.push({\n      json: {\n        siret: etab.siret,\n        siren: etab.siret?.substring(0, 9),\n        company_name: etab.uniteLegale?.denominationUniteLegale || 'N/A',\n        naf_code: etab.uniteLegale?.activitePrincipaleUniteLegale,\n        postal_code: cp,\n        city: etab.adresseEtablissement?.libelleCommuneEtablissement,\n        address_line1: [\n          etab.adresseEtablissement?.numeroVoieEtablissement,\n          etab.adresseEtablissement?.typeVoieEtablissement,\n          etab.adresseEtablissement?.libelleVoieEtablissement\n        ].filter(Boolean).join(' '),\n        source: 'sirene'\n      }\n    });\n  }\n}\n\nreturn result;"
          }
        },
        {
          "id": "geocode",
          "name": "Géocoder adresse → lat/lng",
          "type": "n8n-nodes-base.httpRequest",
          "position": [980, 300],
          "parameters": {
            "method": "GET",
            "url": "https://api-adresse.data.gouv.fr/search/",
            "queryParameters": {
              "parameters": [
                {"name": "q", "value": "={{$json.address_line1}} {{$json.postal_code}} {{$json.city}}"},
                {"name": "limit", "value": "1"}
              ]
            }
          }
        },
        {
          "id": "enrich-coords",
          "name": "Enrich avec coordonnées + distance",
          "type": "n8n-nodes-base.code",
          "position": [1200, 300],
          "parameters": {
            "jsCode": "const CHAUMONT_LAT = 48.111338;\nconst CHAUMONT_LNG = 5.138481;\nconst RAYON_KM = 20;\n\nfunction haversine(lat1, lon1, lat2, lon2) {\n  const R = 6371;\n  const dLat = (lat2 - lat1) * Math.PI / 180;\n  const dLon = (lon2 - lon1) * Math.PI / 180;\n  const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;\n  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));\n}\n\nconst geo = $input.first().json;\nconst prospect = $('filter-distance').first().json;\n\nconst feature = geo?.features?.[0];\nif (!feature) return [];\n\nconst [lng, lat] = feature.geometry.coordinates;\nconst distance = haversine(CHAUMONT_LAT, CHAUMONT_LNG, lat, lng);\n\nif (distance > RAYON_KM) return [];\n\nreturn [{ json: { ...prospect, latitude: lat, longitude: lng, distance_km: Math.round(distance * 100) / 100 } }];"
          }
        },
        {
          "id": "upsert-db",
          "name": "Upsert en base CRM",
          "type": "n8n-nodes-base.httpRequest",
          "position": [1420, 300],
          "parameters": {
            "method": "POST",
            "url": "http://crm_api:4000/api/prospects/import",
            "authentication": "headerAuth",
            "headerAuthKey": "X-API-Key",
