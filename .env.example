# Liderpapel SFTP (set via Supabase Edge Function secrets + local test script)
LIDERPAPEL_SFTP_HOST="sftp.liderpapel.com"
LIDERPAPEL_SFTP_PORT="22"
LIDERPAPEL_SFTP_USER=""
LIDERPAPEL_SFTP_PASSWORD=""
LIDERPAPEL_SFTP_PATH="/"
# LIDERPAPEL_SFTP_CIPHERS=""          # Override cipher list (comma-separated)
# LIDERPAPEL_SFTP_DEBUG="false"       # Enable ssh2 debug logging

