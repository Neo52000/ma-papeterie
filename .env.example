# Supabase — Clés publiques uniquement (anon key)
# NE JAMAIS commiter de service_role_key ou de secrets ici
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"

# Agents SEO Python (local CLI only — .env.local)
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
ANTHROPIC_API_KEY=""

# Icecat enrichment script (local CLI only — .env.local)
SUPABASE_SERVICE_ROLE_KEY=""
ICECAT_API_TOKEN=""
