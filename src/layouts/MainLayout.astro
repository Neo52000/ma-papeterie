---
/**
 * MainLayout — Layout principal pour toutes les pages publiques.
 * Fournit BaseHead (SEO), skip-link, Toaster, Header, Footer et initialisation auth.
 *
 * Note architecture: Les vues React qui embarquent leur propre <Header> et <Footer>
 * (Index, Auth, BlogPage, BlogArticlePage) passent `embedHeader={false}` pour éviter
 * un double-header. Par défaut, MainLayout fournit Header + Footer via HeaderIsland /
 * FooterIsland.
 */
import BaseHead from "./BaseHead.astro";
import ToasterIsland from "@/components/islands/ToasterIsland";
import HeaderIsland from "@/components/islands/HeaderIsland";
import FooterIsland from "@/components/islands/FooterIsland";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  embedHeader?: boolean;
}

const props = Astro.props;
const showHeader = props.embedHeader !== false;
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead {...props} />
  </head>
  <body class="min-h-screen bg-background font-poppins text-foreground antialiased">
    <!-- Skip Navigation -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-primary focus:text-primary-foreground focus:rounded-md focus:text-sm focus:font-medium"
    >
      Aller au contenu principal
    </a>

    {showHeader && <HeaderIsland client:load />}

    <div id="main-content">
      <slot />
    </div>

    {showHeader && <FooterIsland client:load />}

    <!-- Toaster (notifications toast globales) -->
    <ToasterIsland client:only="react" />

    <!-- Error tracking + CWV monitoring + Auth init -->
    <script>
      import { initSentry, captureException } from "@/lib/sentry-config";
      import { useAuthStore } from "@/stores/authStore";

      initSentry();

      // Initialise le listener Supabase auth (onAuthStateChange) dès le chargement
      // de la page. Sans cela, signIn() ne met pas à jour le store Zustand car
      // aucun listener n'est enregistré.
      useAuthStore.getState().init();

      window.addEventListener("unhandledrejection", (event) => {
        captureException(
          event.reason instanceof Error ? event.reason : new Error(String(event.reason))
        );
      });

      import("web-vitals").then(({ onCLS, onINP, onLCP }) => {
        const report = (metric: { name: string; value: number; rating: string }) => {
          if (metric.rating === "poor") {
            captureException(new Error(`Poor CWV: ${metric.name} = ${metric.value}`));
          }
        };
        onCLS(report);
        onINP(report);
        onLCP(report);
      });
    </script>
  </body>
</html>
