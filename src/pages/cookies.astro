---
import MainLayout from "@/layouts/MainLayout.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Cookie, Settings, Shield, BarChart, Target } from "lucide-react";
import { BUSINESS } from "@/data/business-info";
---

<MainLayout
  title="Politique de cookies — Ma Papeterie"
  description="Politique de cookies de Ma Papeterie. Informations sur l'utilisation des cookies sur notre site."
>
  <div class="container mx-auto px-4 py-12">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <Cookie className="h-16 w-16 text-primary mx-auto mb-4" />
        <h1 class="text-4xl font-bold text-primary mb-4">Gestion des Cookies</h1>
        <p class="text-muted-foreground max-w-2xl mx-auto">
          Nous utilisons des cookies pour améliorer votre expérience. Gérez vos préférences ci-dessous.
        </p>
      </div>

      <!-- Préférences -->
      <Card className="mb-8">
        <CardHeader>
          <CardTitle className="flex items-center gap-2">
            <Settings className="h-5 w-5" />
            Vos préférences
          </CardTitle>
        </CardHeader>
        <CardContent className="space-y-6">
          <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
            <div class="flex items-center gap-3">
              <Shield className="h-8 w-8 text-primary" />
              <div>
                <h4 class="font-semibold">Cookies essentiels</h4>
                <p class="text-sm text-muted-foreground">
                  Nécessaires au fonctionnement du site (panier, session, sécurité)
                </p>
              </div>
            </div>
            <span class="text-sm font-medium text-primary">Toujours actifs</span>
          </div>

          <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
            <div class="flex items-center gap-3">
              <BarChart className="h-8 w-8 text-blue-500" />
              <div>
                <h4 class="font-semibold">Cookies analytiques</h4>
                <p class="text-sm text-muted-foreground">
                  Nous aident à comprendre comment vous utilisez le site
                </p>
              </div>
            </div>
            <span class="text-sm text-muted-foreground">Optionnel</span>
          </div>

          <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
            <div class="flex items-center gap-3">
              <Target className="h-8 w-8 text-orange-500" />
              <div>
                <h4 class="font-semibold">Cookies marketing</h4>
                <p class="text-sm text-muted-foreground">
                  Permettent la personnalisation des publicités
                </p>
              </div>
            </div>
            <span class="text-sm text-muted-foreground">Optionnel</span>
          </div>
        </CardContent>
      </Card>

      <!-- Liste des cookies -->
      <div class="space-y-6">
        <h2 class="text-2xl font-bold">Détail des cookies utilisés</h2>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Cookies essentiels</CardTitle>
          </CardHeader>
          <CardContent>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b">
                    <th class="text-left py-2 font-medium">Nom</th>
                    <th class="text-left py-2 font-medium">Finalité</th>
                    <th class="text-left py-2 font-medium">Durée</th>
                  </tr>
                </thead>
                <tbody class="text-muted-foreground">
                  <tr class="border-b">
                    <td class="py-2">sb-auth-token</td>
                    <td class="py-2">Authentification utilisateur</td>
                    <td class="py-2">Session</td>
                  </tr>
                  <tr class="border-b">
                    <td class="py-2">cookie_consent</td>
                    <td class="py-2">Mémorisation des choix cookies</td>
                    <td class="py-2">1 an</td>
                  </tr>
                  <tr>
                    <td class="py-2">cart_items</td>
                    <td class="py-2">Contenu du panier</td>
                    <td class="py-2">7 jours</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Cookies analytiques</CardTitle>
          </CardHeader>
          <CardContent>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b">
                    <th class="text-left py-2 font-medium">Nom</th>
                    <th class="text-left py-2 font-medium">Finalité</th>
                    <th class="text-left py-2 font-medium">Durée</th>
                  </tr>
                </thead>
                <tbody class="text-muted-foreground">
                  <tr class="border-b">
                    <td class="py-2">_ga</td>
                    <td class="py-2">Google Analytics - Identification visiteur</td>
                    <td class="py-2">2 ans</td>
                  </tr>
                  <tr>
                    <td class="py-2">_gid</td>
                    <td class="py-2">Google Analytics - Session</td>
                    <td class="py-2">24 heures</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-lg">Cookies marketing</CardTitle>
          </CardHeader>
          <CardContent>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b">
                    <th class="text-left py-2 font-medium">Nom</th>
                    <th class="text-left py-2 font-medium">Finalité</th>
                    <th class="text-left py-2 font-medium">Durée</th>
                  </tr>
                </thead>
                <tbody class="text-muted-foreground">
                  <tr class="border-b">
                    <td class="py-2">_fbp</td>
                    <td class="py-2">Facebook Pixel - Suivi conversions</td>
                    <td class="py-2">3 mois</td>
                  </tr>
                  <tr>
                    <td class="py-2">fr</td>
                    <td class="py-2">Facebook - Publicité ciblée</td>
                    <td class="py-2">3 mois</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </CardContent>
        </Card>
      </div>
    </div>
  </div>
</MainLayout>
