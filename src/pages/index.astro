---
/**
 * Homepage — SSR on-demand.
 * Fetches "homepage" CMS page metadata server-side for SEO.
 * Index island handles CMS block rendering + fallback sections.
 */
export const prerender = false;

import MainLayout from "@/layouts/MainLayout.astro";
import IndexIsland from "@/components/islands/IndexIsland";
import { createSupabaseServer } from "@/lib/supabase-server";
import { BUSINESS, SCHEMA_ADDRESS } from "@/data/business-info";

const supabase = createSupabaseServer(Astro.request);
const { data: page } = await (supabase as any)
  .from("static_pages")
  .select("meta_title, meta_description, json_ld")
  .eq("slug", "homepage")
  .eq("status", "published")
  .maybeSingle();

const canonical = `${BUSINESS.url}/`;

const title = page?.meta_title
  ?? "Ma Papeterie Reine & Fils — Fournitures bureau et scolaires | Chaumont (52)";
const description = page?.meta_description
  ?? "Papeterie à Chaumont depuis les années 70. Fournitures bureau, scolaires, listes école. Boutique au 10 rue Toupot de Béveaux et livraison en ligne — Reine & Fils.";

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: BUSINESS.tradeName,
  url: BUSINESS.url,
  potentialAction: {
    "@type": "SearchAction",
    target: { "@type": "EntryPoint", urlTemplate: `${BUSINESS.url}/catalogue?q={search_term_string}` },
    "query-input": "required name=search_term_string",
  },
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: BUSINESS.name,
  alternateName: BUSINESS.alternateName,
  url: BUSINESS.url,
  telephone: BUSINESS.phone,
  email: BUSINESS.email,
  address: SCHEMA_ADDRESS,
  geo: { "@type": "GeoCoordinates", latitude: BUSINESS.geo.lat, longitude: BUSINESS.geo.lng },
  priceRange: BUSINESS.priceRange,
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: BUSINESS.hours.weekdays.open, closes: BUSINESS.hours.weekdays.close },
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Saturday"], opens: BUSINESS.hours.saturday.open, closes: BUSINESS.hours.saturday.close },
  ],
};

const jsonLd = [websiteSchema, orgSchema, ...(page?.json_ld ? [page.json_ld] : [])];
---

<MainLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={`${BUSINESS.url}/og-image.png`}
  jsonLd={jsonLd}
>
  <!-- SSR content — visible to crawlers and users before JS loads -->
  <section class="container mx-auto px-4 pt-10 pb-6 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4 font-poppins">
      {BUSINESS.tradeName} — Votre papeterie à {BUSINESS.address.city}
    </h1>
    <p class="text-lg text-muted-foreground max-w-3xl mx-auto mb-6">
      {BUSINESS.name}, papeterie à {BUSINESS.address.city} ({BUSINESS.address.postalCode}) depuis les années 70.
      Plus de 40 000 fournitures de bureau et scolaires sélectionnées par nos experts.
      Conseil personnalisé, livraison rapide, services B2B.
    </p>
    <div class="flex flex-wrap justify-center gap-4 mb-8">
      <a href="/catalogue" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 rounded-md font-medium hover:bg-primary/90 transition-colors">
        Voir le catalogue
      </a>
      <a href="/listes-scolaires" class="inline-flex items-center gap-2 bg-accent text-accent-foreground px-6 py-3 rounded-md font-medium hover:bg-accent/90 transition-colors">
        Listes scolaires
      </a>
    </div>
  </section>

  <!-- Trust strip — key selling points -->
  <section class="bg-muted/50 py-6 mb-8">
    <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
      <div>
        <h3 class="font-semibold text-foreground text-lg">40 000+ références</h3>
        <p class="text-sm text-muted-foreground">Fournitures scolaires, bureau, loisirs créatifs — sélectionnées par nos experts</p>
      </div>
      <div>
        <h3 class="font-semibold text-foreground text-lg">Conseil expert</h3>
        <p class="text-sm text-muted-foreground">Accompagnement personnalisé en boutique à {BUSINESS.address.city} et en ligne</p>
      </div>
      <div>
        <h3 class="font-semibold text-foreground text-lg">Livraison rapide</h3>
        <p class="text-sm text-muted-foreground">Commandez en ligne, retrait en boutique ou livraison partout en France</p>
      </div>
    </div>
  </section>

  <!-- Category navigation -->
  <nav class="container mx-auto px-4 mb-8" aria-label="Catégories principales">
    <h2 class="text-2xl font-bold text-foreground mb-4">Nos catégories</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
      <a href="/catalogue?category=Papeterie" class="rounded-lg border bg-card p-4 text-center hover:border-primary transition-colors">
        <span class="font-medium text-foreground">Papeterie</span>
      </a>
      <a href="/catalogue?category=Bureau" class="rounded-lg border bg-card p-4 text-center hover:border-primary transition-colors">
        <span class="font-medium text-foreground">Bureau</span>
      </a>
      <a href="/catalogue?category=Scolaire" class="rounded-lg border bg-card p-4 text-center hover:border-primary transition-colors">
        <span class="font-medium text-foreground">Scolaire</span>
      </a>
      <a href="/catalogue?category=Loisirs%20Créatifs" class="rounded-lg border bg-card p-4 text-center hover:border-primary transition-colors">
        <span class="font-medium text-foreground">Loisirs créatifs</span>
      </a>
      <a href="/catalogue?category=Technologie" class="rounded-lg border bg-card p-4 text-center hover:border-primary transition-colors">
        <span class="font-medium text-foreground">Technologie</span>
      </a>
      <a href="/catalogue?category=Mobilier" class="rounded-lg border bg-card p-4 text-center hover:border-primary transition-colors">
        <span class="font-medium text-foreground">Mobilier</span>
      </a>
    </div>
  </nav>

  <!-- React island — interactive content (slider, best-sellers, promos, CMS blocks) -->
  <IndexIsland client:only="react" />

  <!-- SEO content — server-rendered text for crawlers -->
  <section class="container mx-auto px-4 py-12">
    <div class="max-w-4xl mx-auto space-y-6">
      <h2 class="text-3xl font-bold text-foreground mb-6">Ma Papeterie : Expert conseil en fournitures scolaires et de bureau</h2>
      <div class="prose prose-lg max-w-none text-muted-foreground space-y-4">
        <p>
          Bienvenue chez <strong>Ma Papeterie</strong>, votre référence en matière de <strong>fournitures scolaires</strong> et <strong>matériel de bureau</strong> à <strong>{BUSINESS.address.city}</strong> en <strong>{BUSINESS.address.region}</strong>. Notre équipe d'experts sélectionne rigoureusement chaque produit pour vous garantir qualité, durabilité et satisfaction, que vous soyez particulier, parent d'élève ou professionnel.
        </p>

        <h3 class="text-2xl font-semibold text-foreground mt-8 mb-4">Votre papeterie à {BUSINESS.address.city}</h3>
        <p>
          Depuis les années 70, <strong>{BUSINESS.name}</strong> accompagne les familles, les écoles et les entreprises de {BUSINESS.address.city} et de toute la <strong>{BUSINESS.address.region}</strong>. Retrouvez-nous au <strong>{BUSINESS.address.street}</strong>, {BUSINESS.address.postalCode} {BUSINESS.address.city}. Horaires : {BUSINESS.hours.display}.
        </p>

        <h3 class="text-2xl font-semibold text-foreground mt-8 mb-4">Particuliers et Professionnels</h3>
        <p>
          Particuliers, établissements scolaires, entreprises : nous accompagnons tous vos projets. Nos <strong>services professionnels B2B</strong> incluent des tarifs dégressifs, la facturation mensuelle, la livraison en gros volumes et un accompagnement personnalisé. Pour les parents, découvrez notre service de <strong>listes scolaires pré-remplies</strong> pour une rentrée sans stress.
        </p>

        <h3 class="text-2xl font-semibold text-foreground mt-8 mb-4">Engagement Écoresponsable</h3>
        <p>
          Conscients des enjeux environnementaux, nous développons constamment notre gamme de <strong>produits écoresponsables</strong> : cahiers en papier recyclé, stylos rechargeables, fournitures en matériaux durables.
        </p>
      </div>
    </div>
  </section>

  <!-- Local business info — server-rendered for crawlers -->
  <section class="bg-muted/50 py-8">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center space-y-3">
        <h2 class="text-xl font-bold text-foreground">Nous trouver</h2>
        <p class="text-muted-foreground">
          <strong>{BUSINESS.name}</strong><br />
          {BUSINESS.address.full}<br />
          Tél : <a href={`tel:${BUSINESS.phone}`} class="text-primary hover:underline">{BUSINESS.phoneDisplay}</a><br />
          Email : <a href={`mailto:${BUSINESS.email}`} class="text-primary hover:underline">{BUSINESS.email}</a><br />
          Horaires : {BUSINESS.hours.display}
        </p>
      </div>
    </div>
  </section>
</MainLayout>
