---
/**
 * Product detail page — SSR on-demand.
 *
 * Server-side:
 *   - Fetches product + images + SEO data + reviews from Supabase
 *   - Generates complete HTML with title, description, OG, Product JSON-LD, BreadcrumbList
 *   - Returns 404 (HTTP status 404) if product not found
 *
 * Client-side (React Islands):
 *   - ProductDetailPage handles gallery, add-to-cart, reviews, recommendations
 */
export const prerender = false;

import MainLayout from "@/layouts/MainLayout.astro";
import ProductDetailPageIsland from "@/components/islands/ProductDetailPageIsland";
import { createSupabaseServer } from "@/lib/supabase-server";
import { BUSINESS } from "@/data/business-info";

const { slug } = Astro.params;
const supabase = createSupabaseServer(Astro.request);

// Fetch product by slug or UUID
let product: any = null;
const uuidPattern = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

if (slug) {
  const col = uuidPattern.test(slug) ? "id" : "slug";
  const { data } = await supabase
    .from("products")
    .select("id, name, slug, description, price, price_ttc, price_ht, brand, ean, sku_interne, manufacturer_ref, image_url, category, subcategory, stock_quantity, is_active")
    .eq(col, slug)
    .eq("is_active", true)
    .maybeSingle();
  product = data;
}

if (!product) {
  Astro.response.status = 404;
}

// All remaining data fetching and schema building is conditional on product existing
let images: any[] = [];
let seo: any = null;
let pageTitle = "Produit introuvable — Ma Papeterie";
let pageDescription = "Ce produit n'existe pas ou n'est plus disponible.";
let canonical = `${BUSINESS.url}/produit/${slug}`;
let ogImage = `${BUSINESS.url}/og-image.png`;
let productSchema: Record<string, any> | null = null;
let breadcrumbSchema: Record<string, any> | null = null;

if (product) {
  // Fetch product images
  const { data: imagesData } = await supabase
    .from("product_images")
    .select("url_originale, alt_seo")
    .eq("product_id", product.id)
    .order("display_order");
  images = imagesData ?? [];

  // Fetch SEO metadata
  const { data: seoData } = await supabase
    .from("product_seo")
    .select("meta_title, meta_description, description_courte")
    .eq("product_id", product.id)
    .eq("status", "approved")
    .maybeSingle();
  seo = seoData;

  // Fetch review stats
  const { data: reviewStats } = await supabase
    .from("product_reviews")
    .select("rating")
    .eq("product_id", product.id)
    .eq("status", "approved");

  const reviewCount = reviewStats?.length ?? 0;
  const avgRating = reviewCount > 0
    ? (reviewStats!.reduce((sum: number, r: any) => sum + r.rating, 0) / reviewCount).toFixed(1)
    : null;

  // Build page meta
  pageTitle = seo?.meta_title || `${product.name}${product.brand ? ` ${product.brand}` : ""} | Ma Papeterie`;
  pageDescription = seo?.meta_description || seo?.description_courte || product.description?.slice(0, 160) || `${product.name} — Fourniture sélectionnée par nos experts.`;
  const canonicalSlug = product.slug || product.id;
  canonical = `${BUSINESS.url}/produit/${canonicalSlug}`;
  ogImage = product.image_url || `${BUSINESS.url}/og-image.png`;
  const price = product.price_ttc || product.price;
  const availability = (product.stock_quantity ?? 0) > 0 ? "https://schema.org/InStock" : "https://schema.org/OutOfStock";

  // Build Product JSON-LD schema
  productSchema = {
    "@context": "https://schema.org",
    "@type": "Product",
    name: product.name,
    description: product.description || product.name,
    image: images?.map((i: any) => i.url_originale) || [product.image_url].filter(Boolean),
    sku: product.sku_interne || product.ean || product.id,
    offers: {
      "@type": "Offer",
      url: canonical,
      priceCurrency: "EUR",
      price: price?.toFixed(2),
      availability,
      seller: { "@type": "Organization", name: "Ma Papeterie" },
    },
  };

  if (product.brand) productSchema.brand = { "@type": "Brand", name: product.brand };
  if (product.ean) productSchema.gtin13 = product.ean;
  if (product.manufacturer_ref) productSchema.mpn = product.manufacturer_ref;
  if (reviewCount > 0 && avgRating) {
    productSchema.aggregateRating = {
      "@type": "AggregateRating",
      ratingValue: avgRating,
      reviewCount,
    };
  }

  // Build BreadcrumbList
  const breadcrumbItems: any[] = [
    { "@type": "ListItem", position: 1, name: "Accueil", item: BUSINESS.url },
    { "@type": "ListItem", position: 2, name: "Catalogue", item: `${BUSINESS.url}/catalogue` },
  ];
  if (product.category) {
    breadcrumbItems.push({
      "@type": "ListItem", position: 3, name: product.category,
      item: `${BUSINESS.url}/catalogue?category=${encodeURIComponent(product.category)}`,
    });
  }
  if (product.subcategory) {
    breadcrumbItems.push({
      "@type": "ListItem", position: breadcrumbItems.length + 1, name: product.subcategory,
    });
  }
  breadcrumbItems.push({
    "@type": "ListItem", position: breadcrumbItems.length + 1, name: product.name,
  });

  breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbItems,
  };
}

const jsonLd = productSchema && breadcrumbSchema ? [productSchema, breadcrumbSchema] : undefined;

// Format price for display
const displayPrice = product ? (product.price_ttc || product.price) : null;
const displayPriceHT = product?.price_ht;
const inStock = product ? (product.stock_quantity ?? 0) > 0 : false;
const productImage = images.length > 0 ? images[0].url_originale : product?.image_url;
const productImageAlt = images.length > 0 ? (images[0].alt_seo || product?.name) : product?.name;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  ogImage={ogImage}
  ogType="product"
  noindex={!product}
  jsonLd={jsonLd}
>
  {product ? (
    <>
      <!-- SSR product summary — visible to crawlers and users before JS loads -->
      <div class="container mx-auto px-4 py-6">
        <!-- Breadcrumb navigation -->
        <nav class="text-sm text-muted-foreground mb-4" aria-label="Fil d'Ariane">
          <a href="/" class="hover:text-primary">Accueil</a>
          <span class="mx-1">/</span>
          <a href="/catalogue" class="hover:text-primary">Catalogue</a>
          {product.category && (
            <>
              <span class="mx-1">/</span>
              <a href={`/catalogue?category=${encodeURIComponent(product.category)}`} class="hover:text-primary">{product.category}</a>
            </>
          )}
          {product.subcategory && (
            <>
              <span class="mx-1">/</span>
              <span>{product.subcategory}</span>
            </>
          )}
        </nav>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Product image -->
          {productImage && (
            <div class="rounded-lg overflow-hidden bg-white border">
              <img
                src={productImage}
                alt={productImageAlt}
                class="w-full h-auto object-contain max-h-[500px]"
                loading="eager"
              />
            </div>
          )}

          <!-- Product info -->
          <div class="space-y-4">
            {product.brand && (
              <span class="inline-block text-sm font-medium text-primary bg-primary/10 px-3 py-1 rounded-full">
                {product.brand}
              </span>
            )}

            <h1 class="text-2xl md:text-3xl font-bold text-foreground">{product.name}</h1>

            {displayPrice != null && (
              <div class="space-y-1">
                <p class="text-3xl font-bold text-primary">
                  {displayPrice.toLocaleString("fr-FR", { style: "currency", currency: "EUR" })} <span class="text-base font-normal text-muted-foreground">TTC</span>
                </p>
                {displayPriceHT != null && (
                  <p class="text-sm text-muted-foreground">
                    {displayPriceHT.toLocaleString("fr-FR", { style: "currency", currency: "EUR" })} HT
                  </p>
                )}
              </div>
            )}

            <p class={`text-sm font-medium ${inStock ? "text-green-600" : "text-orange-600"}`}>
              {inStock ? "En stock" : "Sur commande"}
            </p>

            {product.description && (
              <div class="prose prose-sm max-w-none text-muted-foreground">
                <p>{product.description.length > 500 ? product.description.slice(0, 500) + "..." : product.description}</p>
              </div>
            )}

            <!-- Key attributes -->
            <dl class="grid grid-cols-2 gap-2 text-sm pt-4 border-t">
              {product.category && (
                <>
                  <dt class="text-muted-foreground">Catégorie</dt>
                  <dd class="font-medium">{product.category}</dd>
                </>
              )}
              {product.brand && (
                <>
                  <dt class="text-muted-foreground">Marque</dt>
                  <dd class="font-medium">{product.brand}</dd>
                </>
              )}
              {product.ean && (
                <>
                  <dt class="text-muted-foreground">EAN</dt>
                  <dd class="font-medium">{product.ean}</dd>
                </>
              )}
              {product.sku_interne && (
                <>
                  <dt class="text-muted-foreground">Réf.</dt>
                  <dd class="font-medium">{product.sku_interne}</dd>
                </>
              )}
            </dl>
          </div>
        </div>
      </div>

      <!-- Interactive product page (gallery, cart, reviews) as React Island -->
      <ProductDetailPageIsland client:only="react" />
    </>
  ) : (
    <div class="container mx-auto px-4 py-20 text-center">
      <h1 class="text-4xl font-bold text-primary mb-4">Produit introuvable</h1>
      <p class="text-muted-foreground mb-8">Ce produit n'existe pas ou n'est plus disponible.</p>
      <a href="/catalogue" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 rounded-md font-medium hover:bg-primary/90 transition-colors">
        Voir le catalogue
      </a>
    </div>
  )}
</MainLayout>
