---
/**
 * Consommables index — SSR on-demand.
 * Adds proper SEO metadata + schema. Keeps ConsumablesFinderFull as interactive island.
 */
export const prerender = false;

import MainLayout from "@/layouts/MainLayout.astro";
import Consommables from "@/views/Consommables";
import { BUSINESS } from "@/data/business-info";

const canonical = `${BUSINESS.url}/consommables`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: BUSINESS.url },
    { "@type": "ListItem", position: 2, name: "Consommables", item: canonical },
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Consommables informatiques — Toner, encre & cartouches",
  description: "Trouvez vos consommables d'imprimante en 3 clics : toner, cartouches d'encre, tambours. HP, Canon, Epson, Brother et plus. Originaux et compatibles.",
  provider: { "@type": "LocalBusiness", name: BUSINESS.name, url: BUSINESS.url },
  serviceType: "Vente de consommables d'impression",
  areaServed: { "@type": "Country", name: "France" },
};
---

<MainLayout
  title="Consommables informatiques | Toner, encre & cartouches — Ma Papeterie"
  description="Trouvez vos consommables d'imprimante en 3 clics : toner, cartouches d'encre, tambours. HP, Canon, Epson, Brother et plus. Originaux et compatibles. Livraison rapide."
  canonical={canonical}
  jsonLd={[breadcrumbSchema, serviceSchema]}
>
  <Consommables client:load />
</MainLayout>
