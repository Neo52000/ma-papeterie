---
/**
 * Tampon Designer — index page.
 * BreadcrumbList schema server-side.
 * TamponDesigner is client:only="react" (canvas-based, no SSR possible).
 */
import MainLayout from "@/layouts/MainLayout.astro";
import TamponDesigner from "@/views/TamponDesigner";
import { BUSINESS } from "@/data/business-info";

const canonical = `${BUSINESS.url}/tampon-designer`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: BUSINESS.url },
    { "@type": "ListItem", position: 2, name: "Tampons professionnels", item: `${BUSINESS.url}/tampon-professionnel-chaumont` },
    { "@type": "ListItem", position: 3, name: "Designer", item: canonical },
  ],
};
---

<MainLayout
  title="Designer de tampon personnalisé — Ma Papeterie"
  description="Créez votre tampon professionnel personnalisé en ligne. Choisissez modèle, taille, texte et visualisez le résultat en temps réel."
  canonical={canonical}
  jsonLd={[breadcrumbSchema]}
>
  <TamponDesigner client:only="react" />
</MainLayout>
