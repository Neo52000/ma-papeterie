---
import MainLayout from "@/layouts/MainLayout.astro";
import { Card } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import {
  Armchair, Truck, BadgePercent, Wrench, Phone
} from "lucide-react";
import { FlipbookViewer } from "@/components/emballage/FlipbookViewer";
import { BUSINESS } from "@/data/business-info";

/**
 * ChaisesProductGrid is a complex React component (useState, data fetching, cart).
 * Loaded as a React Island with client:visible.
 */
import ChaisesProductGrid from "@/components/chaises/ChaisesProductGrid";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Chaises Home & Office -- ${BUSINESS.tradeName} Chaumont`,
  "description": "Plus de 400 sieges de bureau, fauteuils ergonomiques et chaises pour la maison et le bureau. Livraison et montage disponibles a Chaumont.",
  "provider": {
    "@type": "LocalBusiness",
    "name": BUSINESS.tradeName,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": BUSINESS.address.city,
      "addressRegion": BUSINESS.address.region,
      "postalCode": BUSINESS.address.postalCode,
      "addressCountry": BUSINESS.address.country,
    },
  },
  "serviceType": "Mobilier de bureau et sieges ergonomiques",
};
---

<MainLayout
  title="Chaises Home & Office -- Sieges et fauteuils de bureau | Ma Papeterie Chaumont"
  description="Decouvrez nos chaises et fauteuils pour la maison et le bureau : sieges ergonomiques, fauteuils de direction, chaises visiteurs. Plus de 400 references a Chaumont."
  canonical="https://ma-papeterie.fr/chaises-home-office"
  jsonLd={serviceSchema}
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary/10 via-background to-secondary/10 py-16 md:py-24">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <Badge variant="secondary" className="mb-4 text-sm">
          <Armchair className="h-3.5 w-3.5 mr-1.5" />
          400+ references
        </Badge>
        <h1 class="text-3xl md:text-5xl font-bold text-foreground mb-6 leading-tight">
          Chaises Home & Office
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground mb-8 max-w-2xl mx-auto">
          Fauteuils de direction, sieges ergonomiques, chaises de bureau et visiteurs --
          le confort au quotidien pour la maison et le bureau.
        </p>
      </div>
    </div>
  </section>

  <!-- Avantages -->
  <section class="py-12 md:py-16">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 max-w-5xl mx-auto">
        <Card className="text-center p-6 hover:shadow-lg transition-shadow">
          <Armchair className="h-10 w-10 text-primary mx-auto mb-3" />
          <h3 class="font-semibold mb-1">Large gamme</h3>
          <p class="text-sm text-muted-foreground">Sieges, fauteuils, ergonomie</p>
        </Card>
        <Card className="text-center p-6 hover:shadow-lg transition-shadow">
          <Wrench className="h-10 w-10 text-primary mx-auto mb-3" />
          <h3 class="font-semibold mb-1">Ergonomie certifiee</h3>
          <p class="text-sm text-muted-foreground">Confort et sante au travail</p>
        </Card>
        <Card className="text-center p-6 hover:shadow-lg transition-shadow">
          <Truck className="h-10 w-10 text-primary mx-auto mb-3" />
          <h3 class="font-semibold mb-1">Livraison & montage</h3>
          <p class="text-sm text-muted-foreground">Service disponible a Chaumont</p>
        </Card>
        <Card className="text-center p-6 hover:shadow-lg transition-shadow">
          <BadgePercent className="h-10 w-10 text-primary mx-auto mb-3" />
          <h3 class="font-semibold mb-1">Prix pro</h3>
          <p class="text-sm text-muted-foreground">Tarifs degressifs B2B</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Catalogue Flipbook -->
  <section id="catalogue-flipbook" class="py-12 md:py-16 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">
          Feuilletez notre catalogue Home & Office
        </h2>
        <p class="text-muted-foreground max-w-xl mx-auto">
          Decouvrez notre gamme complete de sieges et fauteuils dans notre catalogue interactif 2025-2026.
        </p>
      </div>
      <div class="max-w-4xl mx-auto">
        <FlipbookViewer
          client:visible
          pdfUrl="https://mgojmkzovqgpipybelrr.supabase.co/storage/v1/object/public/catalogues/Catalogue%20Chaises%20Home%20%26%20Office%202025-2026.pdf"
          title="Catalogue Chaises Home & Office 2025-2026"
        />
      </div>
    </div>
  </section>

  <!-- Grille Produits -->
  <section class="py-12 md:py-16">
    <div class="container mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">
          Nos sieges et fauteuils
        </h2>
        <p class="text-muted-foreground max-w-xl mx-auto">
          Parcourez notre selection, filtrez par categorie et ajoutez directement au panier.
        </p>
      </div>
      <ChaisesProductGrid client:visible />
    </div>
  </section>

  <!-- CTA B2B -->
  <section class="py-12 md:py-16 bg-primary text-primary-foreground">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <Armchair className="h-12 w-12 mx-auto mb-4 opacity-90" />
        <h2 class="text-2xl md:text-3xl font-bold mb-4">
          Amenagement de bureaux sur mesure ?
        </h2>
        <p class="text-lg mb-8 opacity-90">
          Equipez vos locaux avec nos solutions de mobilier professionnel. Devis gratuit, livraison et montage inclus.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button size="lg" variant="secondary" asChild>
            <a href="/contact">
              <Phone className="h-4 w-4 mr-2" />
              Demander un devis
            </a>
          </Button>
          <Button size="lg" variant="outline" className="border-primary-foreground/30 text-primary-foreground hover:bg-primary-foreground/10" asChild>
            <a href="/leasing-mobilier-bureau">
              Leasing mobilier
            </a>
          </Button>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
