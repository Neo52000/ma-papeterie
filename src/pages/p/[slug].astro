---
/**
 * CMS dynamic page — SSR on-demand.
 *
 * Server-side:
 *   - Fetches static_pages record from Supabase by slug
 *   - Generates HTML with title, description, canonical, JSON-LD, BreadcrumbList
 *   - Returns 404 if page not found or not published
 *
 * Client-side (React Island):
 *   - DynamicPage handles interactive block rendering (forms, accordions…)
 */
export const prerender = false;

import MainLayout from "@/layouts/MainLayout.astro";
import DynamicPage from "@/views/DynamicPage";
import { createSupabaseServer } from "@/lib/supabase-server";
import { BUSINESS } from "@/data/business-info";

const { slug } = Astro.params;
const supabase = createSupabaseServer(Astro.request);

const { data: page } = await supabase
  .from("static_pages")
  .select("id, slug, title, meta_title, meta_description, h1, json_ld, schema_type, status")
  .eq("slug", slug)
  .eq("status", "published")
  .maybeSingle();

if (!page) {
  Astro.response.status = 404;
}

const pageTitle = page?.meta_title || page?.title || "Ma Papeterie";
const pageDescription = page?.meta_description || `${page?.title || "Page"} — Ma Papeterie, fournitures scolaires et de bureau à Chaumont.`;
const canonical = `${BUSINESS.url}/p/${slug}`;

// BreadcrumbList JSON-LD
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: BUSINESS.url },
    { "@type": "ListItem", position: 2, name: page?.h1 || page?.title || slug },
  ],
};

const schemas: object[] = [breadcrumbSchema];
if (page?.json_ld) schemas.push(page.json_ld as object);
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  jsonLd={schemas}
  noindex={!page}
>
  {page ? (
    <DynamicPage client:load />
  ) : (
    <div class="container mx-auto px-4 py-20 text-center">
      <h1 class="text-4xl font-bold text-primary mb-4">Page introuvable</h1>
      <p class="text-muted-foreground mb-8">Cette page n'existe pas ou n'est pas disponible.</p>
      <a href="/" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 rounded-md font-medium hover:bg-primary/90 transition-colors">
        Retour à l'accueil
      </a>
    </div>
  )}
</MainLayout>
