---
/**
 * Reprographie — SSR on-demand.
 * Service + BreadcrumbList schemas server-side.
 * ServiceOrderTunnel island handles the multi-step order form.
 */
export const prerender = false;

import MainLayout from "@/layouts/MainLayout.astro";
import ServiceReprographie from "@/views/ServiceReprographie";
import { BUSINESS, SCHEMA_ADDRESS } from "@/data/business-info";

const canonical = `${BUSINESS.url}/services/reprographie`;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Reprographie en ligne",
  serviceType: "Reprographie",
  description: "Service de reprographie en ligne : impression de documents A4/A3, noir & blanc ou couleur. Upload, payez en ligne et récupérez en boutique.",
  url: canonical,
  provider: {
    "@type": "LocalBusiness",
    name: BUSINESS.name,
    url: BUSINESS.url,
    telephone: BUSINESS.phone,
    address: SCHEMA_ADDRESS,
  },
  areaServed: { "@type": "City", name: BUSINESS.address.city },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: BUSINESS.url },
    { "@type": "ListItem", position: 2, name: "Services", item: `${BUSINESS.url}/services` },
    { "@type": "ListItem", position: 3, name: "Reprographie", item: canonical },
  ],
};
---

<MainLayout
  title="Reprographie en ligne — Ma Papeterie"
  description="Service de reprographie en ligne : impression de documents A4/A3, noir & blanc ou couleur. Upload, payez en ligne et récupérez en boutique."
  canonical={canonical}
  jsonLd={[serviceSchema, breadcrumbSchema]}
  noindex={true}
>
  <ServiceReprographie client:load />
</MainLayout>
