---
/**
 * Blog article page — SSR on-demand.
 *
 * Server-side:
 *   - Fetches article + SEO metadata from Supabase
 *   - Generates HTML with title, description, OG, BlogPosting + BreadcrumbList JSON-LD
 *   - Returns HTTP 404 if article not found or not published
 *
 * Client-side:
 *   - BlogArticlePage handles comments, sharing, related articles
 */
export const prerender = false;

import MainLayout from "@/layouts/MainLayout.astro";
import BlogArticlePage from "@/views/BlogArticlePage";
import { createSupabaseServer } from "@/lib/supabase-server";
import { BUSINESS } from "@/data/business-info";

const { slug } = Astro.params;
const supabase = createSupabaseServer(Astro.request);

// Fetch article
const { data: article } = await supabase
  .from("blog_articles")
  .select("id, title, slug, excerpt, image_url, published_at, updated_at, category, blog_seo_metadata(*)")
  .eq("slug", slug)
  .eq("status", "published")
  .maybeSingle();

if (!article) {
  Astro.response.status = 404;
}

// Build page meta (conditional on article existing)
let pageTitle = "Article introuvable — Ma Papeterie";
let pageDescription = "Cet article n'existe pas ou n'est plus disponible.";
let canonical = `${BUSINESS.url}/blog/${slug}`;
let ogImage = `${BUSINESS.url}/og-image.png`;
let blogPostingSchema: Record<string, any> | null = null;
let breadcrumbSchema: Record<string, any> | null = null;

if (article) {
  const metadata = article.blog_seo_metadata?.[0] || article.blog_seo_metadata;

  pageTitle = `${article.title} — Ma Papeterie`;
  pageDescription = metadata?.meta_description || article.excerpt?.slice(0, 160) || article.title;
  canonical = `${BUSINESS.url}/blog/${article.slug}`;
  ogImage = metadata?.og_image_url || article.image_url || `${BUSINESS.url}/og-image.png`;

  // BlogPosting JSON-LD
  blogPostingSchema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: article.title,
    description: article.excerpt || article.title,
    image: ogImage,
    datePublished: article.published_at,
    dateModified: article.updated_at || article.published_at,
    author: { "@type": "Organization", name: "Ma Papeterie", url: BUSINESS.url },
    publisher: { "@type": "Organization", name: "Ma Papeterie", url: BUSINESS.url },
    mainEntityOfPage: canonical,
    ...(metadata?.keywords?.length ? { keywords: metadata.keywords.join(", ") } : {}),
    ...(metadata?.word_count ? { wordCount: metadata.word_count } : {}),
  };

  // BreadcrumbList JSON-LD
  breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Accueil", item: BUSINESS.url },
      { "@type": "ListItem", position: 2, name: "Blog", item: `${BUSINESS.url}/blog` },
      { "@type": "ListItem", position: 3, name: article.title },
    ],
  };
}

const jsonLd = blogPostingSchema && breadcrumbSchema ? [blogPostingSchema, breadcrumbSchema] : undefined;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  noindex={!article}
  jsonLd={jsonLd}
>
  {article ? (
    <BlogArticlePage client:load />
  ) : (
    <div class="container mx-auto px-4 py-20 text-center">
      <h1 class="text-4xl font-bold text-primary mb-4">Article introuvable</h1>
      <p class="text-muted-foreground mb-8">Cet article n'existe pas ou n'est plus disponible.</p>
      <a href="/blog" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 rounded-md font-medium hover:bg-primary/90 transition-colors">
        Voir tous les articles
      </a>
    </div>
  )}
</MainLayout>
